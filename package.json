{
  "main": "dist/src/index.js",
  "scripts": {
    "start": "npx tsc && node dist/src/index.js",
    "build:": "npx tsc -p tsconfig.json && rm -rf ./dist/public && cp -R ./public ./dist/public",
    "dev": "nodemon src/index.ts --ext .js,.ts,.html,.json",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "check:types": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src/**/*.ts"
  },
  "dependencies": {
    "@types/express": "^4.17.13",
    "@types/node": "^24.0.0",
    "axios": "^1.17.0",
    "cors": "^2.8.5",
    "ejs": "^3.1.6",
    "express": "^4.17.1",
    "js-yaml": "^4.1.0",
    "socket.io": "^4.4.0",
    "typescript": "^5.9.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@types/ejs": "^3.1.5",
    "@types/js-yaml": "^4.0.9",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@vitest/coverage-istanbul": "^4.1.7",
    "eslint": "^10.4.0",
    "lefthook": "^2.1.8",
    "lint-staged": "^17.0.5",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3",
    "ts-node": "^10.4.0",
    "vitest": "^4.1.7"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "engines": {
    "node": ">=24.16.0"
  }
}
